# Firecrawl API key — https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# OpenAI API key — używany do embeddingów (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Claude Code OAuth token — pobierz z: ~/.claude/credentials.json (pole "oauthToken")
# lub z ustawień konta na claude.ai. Pozwala na autentykację claude CLI bez interaktywnego logowania.
CLAUDE_CODE_OAUTH_TOKEN=sk-oat...

# Liczba równoległych instancji agenta (nadpisuje config.yaml crawler_workers)
CRAWLER_WORKERS=1

# Qdrant connection
# Lokalnie (poza Dockerem): http://localhost:6333
# Wewnątrz Docker Compose:  http://qdrant:6333
QDRANT_URL=http://localhost:6333
