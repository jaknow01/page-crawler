# Firecrawl API key — https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# OpenAI API key — używany do embeddingów (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Autentykacja Claude Code CLI — jeden z dwóch sposobów:
#   Opcja A: klucz API (generowany na console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
#   Opcja B: OAuth long-term token (z ~/.claude/credentials.json → pole "oauthToken")
CLAUDE_CODE_OAUTH_TOKEN=sk-oat-...

# Liczba równoległych instancji agenta (nadpisuje config.yaml crawler_workers)
CRAWLER_WORKERS=1

# Qdrant connection
# Wewnątrz Docker Compose: ustawiane automatycznie jako http://qdrant:6333
# Lokalnie (poza Dockerem):
QDRANT_URL=http://localhost:6333
